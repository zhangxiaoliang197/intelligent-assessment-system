# ============================================================
# 智能评估系统 - 环境变量模板
# ------------------------------------------------------------
# 复制本文件为 .env 并填入实际值：
#   cp .env.example .env      (Linux/Mac)
#   copy .env.example .env    (Windows)
#
# .env 文件已被 .gitignore 忽略，不会提交到版本库。
# 切勿在 .env 中填写生产环境真实密码后提交。
# ============================================================

# ─── admin-service (Java) ───
SERVER_PORT=10258

# ─── 元数据库类型: h2 | mysql | postgresql ───
DB_TYPE=mysql

# ─── MySQL 连接 ───
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=assessment
MYSQL_USER=root
MYSQL_PASSWORD=

# ─── PostgreSQL 连接 ───
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=assessment
PG_USER=postgres
PG_PASSWORD=

# ─── Python 服务间调用地址 ───
ADMIN_SERVICE_URL=http://localhost:10258
KNOWLEDGE_SERVICE_URL=http://localhost:10252
QA_SERVICE_URL=http://localhost:10253
EVALUATION_API_URL=http://localhost:10253

# ─── 大模型配置 ───
LLM_API_URL=http://localhost:8000/v1
LLM_API_KEY=

# ─── 对话上下文轮数 ───
QA_CONTEXT_ROUNDS=5
INDICATOR_CONTEXT_ROUNDS=5
