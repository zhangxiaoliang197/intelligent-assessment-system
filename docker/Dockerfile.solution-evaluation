FROM python:3.11-slim
WORKDIR /app
RUN pip config set global.index-url https://pypi.tuna.tsinghua.edu.cn/simple
COPY python/solution-evaluation-service/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY python/solution-evaluation-service/ .
EXPOSE 10259
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "10259"]
